{
  "name": "@edit/cli",
  "version": "0.1.0",
  "description": "Open-source visual editor for any web project",
  "type": "module",
  "bin": {
    "edit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "visual-editor",
    "web-editor",
    "wysiwyg",
    "html-editor",
    "css-editor"
  ],
  "license": "MIT",
  "dependencies": {
    "cac": "^6.7.14",
    "parse5": "^7.2.1",
    "picocolors": "^1.1.1",
    "vite": "^6.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
